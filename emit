set -eu

if [ -z "${1-}" ]; then
    printf '%s\n' 'missing argument 1 (out file)' >&2
    exit 1
fi

out="$1"
: > "$out"
emit_raw() {
    printf '%s' "$1" >> "$out"
}

emit_hex() {
    bytes=
    for byte do
        bytes="${bytes}\\$(printf '%03o' "0x$byte")"
    done
    printf '%b' "$bytes" >> "$out"
}
